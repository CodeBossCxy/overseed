# ===========================================
# DATABASE
# ===========================================
# See docs/DATABASE_SETUP.md for full setup guide

# LOCAL DEVELOPMENT (choose one):
# - Homebrew install (no password): postgresql://YOUR_MAC_USERNAME@localhost:5432/overseeddb
# - Docker: postgresql://postgres:devpassword@localhost:5432/overseeddb
# - Postgres.app: postgresql://YOUR_MAC_USERNAME@localhost:5432/overseeddb

DATABASE_URL="postgresql://postgres@localhost:5432/overseeddb"

# PRODUCTION (set in hosting platform, not here):
# - Supabase: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# - Neon: postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/neondb?sslmode=require
# - Vercel: Auto-configured when you add Vercel Postgres

# ===========================================
# NEXTAUTH
# ===========================================
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ===========================================
# OAUTH PROVIDERS
# ===========================================

# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth
# Get from: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# WeChat OAuth
# Get from: https://open.weixin.qq.com/
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# ===========================================
# EMAIL (Optional - for magic links)
# ===========================================
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="noreply@overseed.net"
