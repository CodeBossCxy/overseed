{
  "name": "overseed",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/prisma-adapter": "^1.0.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@hookform/resolvers": "^3.3.2",
    "@prisma/client": "^5.20.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^2.4.3",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "next": "^15.5.12",
    "next-auth": "^4.24.5",
    "nodemailer": "^6.10.1",
    "openai": "^6.25.0",
    "pdfkit": "^0.18.0",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^21.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
